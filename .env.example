# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN="token"

# Groq API Key for Whisper transcription
GROQ_API_KEY="key"

# Anthropic API Key for LLM
ANTHROPIC_API_KEY="key"

# OpenAI Base URL for LLM
ANTHROPIC_BASE_URL="https://api.minimax.io/anthropic"

# OpenAI Model for LLM
ANTHROPIC_MODEL="MiniMax-M2.7"

# The JWT secret
JWT_SECRET="secret"

# Admin username
ADMIN_USER="admin"

# Admin password
ADMIN_PASSWORD="password"

# Allowed origin for CORS (your Netlify frontend URL)
ALLOWED_ORIGIN="https://your-app.netlify.app"

# Frontend API URL (your Oracle Cloud backend URL)
VITE_API_URL="http://your-oci-ip:3000"

# Token key for frontend localStorage
VITE_TOKEN_KEY='token'